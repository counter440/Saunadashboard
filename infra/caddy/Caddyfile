# Caddy reverse proxy for sauna-monitor.
# Local dev: hits localhost on :80 → proxies to the Next.js dev server on :3000.
# Production: replace `:80` with `{$APP_HOSTNAME}` to enable auto-HTTPS.

:80 {
	reverse_proxy host.docker.internal:3000
}

# Production config (uncomment after DNS points here):
#
