{
  "name": "sauna-monitor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10"
  },
  "scripts": {
    "dev:ingest": "pnpm --filter @sauna/ingest dev",
    "dev:notifier": "pnpm --filter @sauna/notifier dev",
    "dev:web": "pnpm --filter @sauna/web dev",
    "fake-device": "tsx scripts/fake-device.ts",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "infra:up": "docker compose -f infra/docker-compose.yml --env-file .env up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml --env-file .env down",
    "infra:logs": "docker compose -f infra/docker-compose.yml logs -f",
    "db:migrate": "tsx scripts/migrate.ts",
    "seed:super-admin": "tsx scripts/seed-super-admin.ts",
    "vapid:generate": "tsx scripts/generate-vapid.ts",
    "mosquitto:passwd": "docker compose -f infra/docker-compose.yml exec mosquitto mosquitto_passwd -b /mosquitto/config/passwd"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.7.5",
    "@types/pg": "^8.11.10",
    "@types/web-push": "^3.6.4",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "pg": "^8.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "web-push": "^3.6.7"
  }
}
