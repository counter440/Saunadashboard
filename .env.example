# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=sauna
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=sauna
POSTGRES_PORT=5432
DATABASE_URL=postgres://sauna:change-me-in-prod@localhost:5432/sauna

# ── MQTT broker (Mosquitto) ───────────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883                 # local dev: plaintext
MQTT_TLS_PORT=8883             # production: TLS
MQTT_INGEST_USER=ingest
MQTT_INGEST_PASS=change-me-ingest

# ── Ingest service ────────────────────────────────────────────────────────
INGEST_LOG_LEVEL=info

# ── Notifier ──────────────────────────────────────────────────────────────
NOTIFIER_LOG_LEVEL=info

# ── Web Push (PWA notifications) ──────────────────────────────────────────
# Generate with: pnpm vapid:generate
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# ── Web (Next.js) ─────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-with-openssl-rand-base64-32
PUBLIC_APP_NAME=Ember

# ── Caddy / production hostname ───────────────────────────────────────────
APP_HOSTNAME=sauna-monitor.example.com
